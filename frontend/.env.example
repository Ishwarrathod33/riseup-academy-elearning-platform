# --- Local development (recommended) ---
# Leave NEXT_PUBLIC_API_BASE_URL unset or empty so the browser calls /api/... on :3000
# and Next.js proxies to the backend (see next.config.mjs rewrites).
# Backend: cd ../backend && npm run dev   (default http://127.0.0.1:8080)
#
# NEXT_PUBLIC_API_BASE_URL=

# Optional: if the API runs on another host/port, set the proxy target (server-side only):
# BACKEND_URL=http://127.0.0.1:8080

# --- Direct API URL (skip proxy) ---
# Uncomment only if you need the browser to talk to Express directly (CORS must allow your origin).
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
